# Mock credentials for local development.
# Copy to .env (untracked) and fill in real values — NEVER commit real tokens.
# SSO JWTs expire 8 hours after minting; refresh your .env the same day.

# Raw SSO JWT from the FinX handoff (sent as-is, no "Bearer" prefix)
FINX_SSO_JWT=paste-sso-jwt-here

# Session token from the FinX handoff (X-Session-Id header / upstream `from` header)
FINX_SESSION=paste-session-token-here

# Decrypted test client code (X-User-Id header / upstream InvCode)
FINX_TEST_CLIENT_ID=X0xxxxx

# Optional backend overrides (defaults shown; see backend/README.md)
# UPSTREAM_PROFILE_URL=https://mf.choiceindia.com/api/v2/investor/profile/extended
# UPSTREAM_TIMEOUT_SECONDS=10

# DeepEval tracing (CHO-244) — observability of the agent loop.
# Set CONFIDENT_API_KEY to export traces to the Confident AI dashboard; with no
# key tracing is entirely off (zero latency, no behaviour change). Get the key
# from `deepeval login` / the Confident AI app. Never commit a real key.
# CONFIDENT_API_KEY=paste-confident-ai-key-here
# DEEPEVAL_ENV=development           # development | staging | production
# DEEPEVAL_SAMPLING_RATE=1.0         # fraction of turns to trace (0.0–1.0)
# DEEPEVAL_TRACING=0                 # 1 = collect locally without a Confident key
