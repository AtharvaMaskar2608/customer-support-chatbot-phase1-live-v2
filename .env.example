# Mock credentials for local development.
# Copy to .env (untracked) and fill in real values — NEVER commit real tokens.
# SSO JWTs expire 8 hours after minting; refresh your .env the same day.

# Raw SSO JWT from the FinX handoff (sent as-is, no "Bearer" prefix)
FINX_SSO_JWT=paste-sso-jwt-here

# Session token from the FinX handoff (X-Session-Id header / upstream `from` header)
FINX_SESSION=paste-session-token-here

# Decrypted test client code (X-User-Id header / upstream InvCode)
FINX_TEST_CLIENT_ID=X0xxxxx

# Optional backend overrides (defaults shown; see backend/README.md)
# UPSTREAM_PROFILE_URL=https://mf.choiceindia.com/api/v2/investor/profile/extended
# UPSTREAM_TIMEOUT_SECONDS=10

# Agent tracing (CHO-261) — self-hosted observability of the agent loop.
# Each /api/chat turn is captured as an execution graph and stored in our OWN
# Postgres (agent_traces table) — no external service, no egress, no cost.
# ON by default; persistence needs the DB pool (DATABASE_URL) at request time.
# AGENT_TRACING=1                    # 0/false/off to disable tracing
# TRACING_SALT=jini-tracing          # HMAC salt pseudonymising thread/user ids

# Trace viewer dashboard (CHO-262) — the admin-gated /traces UI over the traces.
# UNSET ⇒ every /api/traces* endpoint returns 404 (dashboard fully off). Set it
# to a long random secret to enable; the UI sends it as the X-Traces-Token header.
# TRACES_ADMIN_TOKEN=paste-a-long-random-admin-token-here

# Agent model (CHO-270) — defaults to Sonnet 4.6 with thinking off (smallest).
# AGENT_MODEL=claude-sonnet-4-6      # or claude-haiku-4-5
# AGENT_THINKING=off                 # or minimal
